# ==========================================
# KONFIGURASI BOT WHATSAPP AUTO ORDER
# Salin file ini menjadi ".env" lalu isi sesuai kebutuhan
# ==========================================

# --- Identitas Bot ---
BOT_NAME=Digital Store
BOT_NUMBER=628xxxxxxxxxx
# Nomor yang dipakai untuk generate Pairing Code (nomor bot itu sendiri)
PAIRING_NUMBER=628xxxxxxxxxx

# --- Owner ---
# Bisa lebih dari satu, pisahkan dengan koma. Format: 628xxxxxxxxxx
OWNER_NUMBERS=628xxxxxxxxxx

# --- Mode Login Baileys ---
# true = pakai Pairing Code, false = pakai QR Code di terminal
USE_PAIRING_CODE=true

# --- Xendit Payment Gateway ---
XENDIT_API_KEY=xnd_development_xxxxxxxxxxxxxxxxxxxx
XENDIT_WEBHOOK_TOKEN=isi_dengan_verification_token_dari_dashboard_xendit
XENDIT_MERCHANT_CODE=ISI_MERCHANT_CODE
XENDIT_CALLBACK_URL=https://domain-anda.com/webhook/xendit

# --- Server Webhook (Express) ---
PORT=3000

# --- Database ---
DB_PATH=./database/store.db

# --- Lain-lain ---
CURRENCY=IDR
INVOICE_EXPIRY_MINUTES=30
TIMEZONE=Asia/Jakarta
